# Personal Brand site environment variables
# Copy to .env.local for local development
# Configure on the deploy host (Lovable, Vercel, etc.) for production

# External brand links (used in Footer + Navbar + Work With Me + Articles)
VITE_IMPACT_LOOP_URL=https://impactloop.ca
VITE_LINKEDIN_URL=https://www.linkedin.com/in/rovonnrussell
VITE_YOUTUBE_URL=https://youtube.com/@rovonnrussell
VITE_INSTAGRAM_URL=https://instagram.com/rovonnrussell

# Booking link (used on Work With Me page)
# Phase 1: Calendly or Cal.com URL
# Phase 2: replace with custom booking integration to Impact Loop's booking system
VITE_ADVISORY_BOOKING_URL=https://cal.com/rovonnrussell/discovery-call

# Existing Supabase config (already set in current .env)
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# Supabase Edge Functions base URL. Example: https://<project-ref>.supabase.co/functions/v1
VITE_SUPABASE_FUNCTIONS_URL=https://<project-ref>.supabase.co/functions/v1
